# Copia este archivo a .env.local y rellena los valores reales.
# .env.local nunca se sube al repositorio (ver .gitignore).

# Discord Developer Portal > tu aplicación > OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ID del servidor de Discord de la guild (clic derecho sobre el servidor
# con el modo desarrollador activado > Copiar ID de servidor)
DISCORD_GUILD_ID=

# La URL del webhook de Discord ya NO es una variable de entorno: se
# configura desde /admin (tabla MarketConfig), editable sin redesplegar.

# Opcional. Token de un bot de Discord (Developer Portal > tu aplicación >
# Bot > Reset Token), invitado al servidor de la guild. Solo se usa para que
# /admin pueda listar los roles del servidor por nombre al elegir quién más
# (aparte de quien tenga el permiso Administrator) accede al panel — sin
# esto, se introducen los IDs de rol a mano. Nunca se guarda en base de
# datos. El mismo bot servirá en el futuro para las DMs de transacción.
DISCORD_BOT_TOKEN=

# Secreto para firmar la sesión de NextAuth. Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Desarrollo local (docker-compose up -d db):
# POSTGRES_PRISMA_URL=postgresql://postgres:postgres@localhost:5433/ro_guild_market
# POSTGRES_URL_NON_POOLING=postgresql://postgres:postgres@localhost:5433/ro_guild_market
#
# Producción: NO se rellenan a mano. Al conectar la integración Vercel↔Supabase
# en el dashboard de Vercel, ambas variables se crean y mantienen solas.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# URL pública de la app, para construir enlaces absolutos (webhooks de Discord, etc.).
# Local: http://localhost:3000 — en producción, el dominio real de Vercel.
APP_URL=http://localhost:3000

# API key de Gemini (https://aistudio.google.com/apikey), para el reconocimiento
# de item a partir de una captura del tooltip en el formulario de venta.
GEMINI_API_KEY=
