generator client {
  provider = "prisma-client-js"
}

// Nombres de la integración Vercel↔Supabase (auto-sincronizados en
// producción; en local apuntan al Postgres de docker-compose, ver .env).
datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum ItemCategory {
  WEAPON
  ARMOR
  CARD
  CONSUMABLE
  COSTUME
  PET
  ENCHANT
  ETC
}

// Slot que ocupa una armadura, o slot compatible de una carta.
enum EquipSlot {
  UPPER_HEADGEAR
  MID_HEADGEAR
  LOWER_HEADGEAR
  ARMOR
  SHIELD
  GARMENT
  FOOTGEAR
  ACCESSORY
  WEAPON
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

model User {
  // Igual al id de Discord (snowflake): no hay otro proveedor de login.
  id         String   @id
  username   String
  avatarUrl  String?
  guildRoles String[] @default([])
  createdAt  DateTime @default(now())

  listings  Listing[]
  purchases Purchase[]
}

model Item {
  id          String       @id @default(cuid())
  name        String
  description String?
  category    ItemCategory
  // Slot de equipo (armaduras) o slot en el que se puede montar (cartas).
  slot        EquipSlot?
  // Copia propia del icono (sin hotlink a la fuente externa).
  iconUrl     String
  // Ficha de origen del scraping, para trazabilidad.
  sourceUrl   String?
  scrapedAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  listings Listing[]

  @@index([category, slot])
  @@index([name])
}

// Fase 1: solo venta directa. Los campos de subasta se añaden en la Fase 2.
model Listing {
  id           String        @id @default(cuid())
  seller       User          @relation(fields: [sellerId], references: [id])
  sellerId     String
  item         Item          @relation(fields: [itemId], references: [id])
  itemId       String
  quantity     Int           @default(1)
  // Suma desnormalizada de Purchase.quantity, para no recalcularla en cada
  // lectura. Se actualiza en la misma transacción que crea cada Purchase.
  quantitySold Int           @default(0)
  price        Int
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  purchases Purchase[]

  @@index([status, createdAt])
  @@index([price])
}

// Registro inmutable de cada compra (norma 3 del plan: las transacciones no
// se borran). Una Listing puede tener varias Purchase de distintos
// compradores hasta agotar su quantity.
model Purchase {
  id        String   @id @default(cuid())
  listing   Listing  @relation(fields: [listingId], references: [id])
  listingId String
  buyer     User     @relation(fields: [buyerId], references: [id])
  buyerId   String
  quantity  Int
  unitPrice Int
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([buyerId])
}
